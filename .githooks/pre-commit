#!/usr/bin/env bash
# Pre-commit checks for bookmarker.
#
# Enable once per clone:
#     git config core.hooksPath .githooks
#
# Skip the hook for a single commit with:  git commit --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

staged() { git diff --cached --name-only --diff-filter=ACM -- "$@"; }

STATUS=0

# 1. Validate bookmarks.yaml when it's staged.
if staged data/bookmarks.yaml | grep -q .; then
  echo "[pre-commit] Validating data/bookmarks.yaml..."
  if ! python3 scripts/sync_bookmarks.py --validate-only --yaml data/bookmarks.yaml --quiet; then
    echo "[pre-commit] bookmarks.yaml failed validation — commit aborted." >&2
    STATUS=1
  fi
fi

# 2. Ruff lint on staged Python files.
# Invoked as `python3 -m ruff` / `python3 -m pytest` to match the same Python
# interpreter as sync_bookmarks.py — avoids the classic "pytest from one venv,
# PyYAML from another" import failure.
PY_FILES=$(staged '*.py' || true)
if [[ -n "$PY_FILES" ]]; then
  if python3 -c "import ruff" 2>/dev/null || python3 -m ruff --version >/dev/null 2>&1; then
    echo "[pre-commit] Ruff checking staged Python files..."
    if ! echo "$PY_FILES" | xargs python3 -m ruff check; then
      echo "[pre-commit] Ruff found issues — commit aborted." >&2
      STATUS=1
    fi
  else
    echo "[pre-commit] Skipping ruff (not installed — pip install ruff)." >&2
  fi

  # 3. Pytest when tests or production code under scripts/ change.
  if python3 -m pytest --version >/dev/null 2>&1; then
    echo "[pre-commit] Running pytest..."
    if ! python3 -m pytest -q; then
      echo "[pre-commit] Tests failed — commit aborted." >&2
      STATUS=1
    fi
  else
    echo "[pre-commit] Skipping pytest (not installed — pip install pytest)." >&2
  fi
fi

# 4. Shellcheck on staged shell scripts.
SH_FILES=$(staged '*.sh' || true)
if [[ -n "$SH_FILES" ]] && command -v shellcheck >/dev/null 2>&1; then
  echo "[pre-commit] Shellcheck on staged shell scripts..."
  if ! echo "$SH_FILES" | xargs shellcheck; then
    echo "[pre-commit] Shellcheck found issues — commit aborted." >&2
    STATUS=1
  fi
fi

exit $STATUS
